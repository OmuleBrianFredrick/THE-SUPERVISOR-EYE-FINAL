# ==============================================
# SUPERVISOR EYE — ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control
# On Replit, add these values in the Secrets panel instead
# ==============================================


# ----------------------------------------------
# DATABASE (required)
# ----------------------------------------------
# Get this from Neon: https://neon.tech
DATABASE_URL=postgresql://user:password@host:5432/dbname


# ----------------------------------------------
# SESSION (required)
# ----------------------------------------------
# Any long random string — keep it secret
SESSION_SECRET=your_strong_random_secret_here


# ----------------------------------------------
# GOOGLE OAUTH (required for Google login)
# ----------------------------------------------
# Get these from: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be set to:
# https://supervisor-eye--omulebrianfredr.replit.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret


# ----------------------------------------------
# EMAIL / NODEMAILER (optional)
# ----------------------------------------------
# Only needed if you want the app to send emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Supervisor Eye <noreply@supervisoreye.com>"


# ----------------------------------------------
# APP
# ----------------------------------------------
NODE_ENV=production
PORT=5000


# ----------------------------------------------
# SUPER ADMIN (optional)
# ----------------------------------------------
# The user with this email will automatically get super admin privileges on registration
SUPERADMIN_EMAIL=your_admin_email@gmail.com
